{
  "name": "effect-ts-tutorial",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@11.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm gen && tsc -b && vite build",
    "gen": "tsx scripts/build-vendor.ts && tsx scripts/build-types.ts",
    "predev": "tsx scripts/ensure-generated.ts",
    "check-doc-links": "tsx scripts/check-doc-links.ts",
    "lint": "oxlint",
    "preview": "pnpm run build && wrangler dev",
    "e2e": "playwright test",
    "deploy": "pnpm run build && wrangler deploy",
    "verify-lessons": "tsx scripts/verify-lessons.ts",
    "typecheck-content": "tsc -p tsconfig.content.json",
    "build:og": "tsx scripts/build-og.ts",
    "prerender": "tsx scripts/prerender.ts"
  },
  "dependencies": {
    "@effect/platform": "^0.97.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@monaco-editor/react": "^4.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "^3.22.0",
    "esbuild-wasm": "^0.28.1",
    "lucide-react": "^1.25.0",
    "monaco-editor": "^0.55.1",
    "monaco-vim": "^0.4.4",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.12.2",
    "react-router": "^8.2.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.13.1",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.9.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@cloudflare/workers-types": "^5.20260718.1",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@playwright/test": "^1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "satori": "^0.28.0",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wrangler": "^4.112.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
