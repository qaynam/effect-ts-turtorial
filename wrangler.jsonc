{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "effect-ts-tutorial",
  "compatibility_date": "2026-07-19",
  "main": "./src/worker.ts",
  "observability": {
    "enabled": true
  },
  "assets": {
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/", "/tutorial/*"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
